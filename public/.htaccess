# ── asensios.com · Apache / LiteSpeed (Hostinger) ───────────────────────────

# Legacy route preserved -> new equivalent page
Redirect 301 /trajectory.html /business/
Redirect 301 /trajectory     /business/

<IfModule mod_rewrite.c>
  RewriteEngine On

  # If the request maps to an existing file or directory, serve it as-is
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Allow /business and /games (without trailing slash) to resolve
  RewriteRule ^business/?$ /business/index.html [L]
  RewriteRule ^games/?$    /games/index.html    [L]
</IfModule>

# Default document
DirectoryIndex index.html

# ── Compression ─────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# ── Caching ─────────────────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  # Hashed build assets — cache hard
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  # HTML — always revalidate so new deploys show up immediately
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
